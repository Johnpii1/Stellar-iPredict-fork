# ── Oracle configuration ──────────────────────────────────────────────────────
# Copy to .env and fill in real values.

# Stellar / Soroban
SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com
NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
MARKET_CONTRACT_ID=

# Oracle provider signing key (KEEP SECRET — never commit a real one)
ORACLE_SECRET_KEY=

# Council aggregator
COUNCIL_THRESHOLD=4
COUNCIL_SIZE=7

# Optimistic oracle (Phase 2)
SUBMITTER_BOND_XLM=100
DISPUTER_BOND_XLM=200

# Data source API keys
COINGECKO_API_KEY=
BINANCE_API_KEY=
SPORTS_API_KEY=
ODDS_API_KEY=

# Monitoring / alerting
ALERT_WEBHOOK_URL=
MARKET_UNRESOLVED_ALERT_HOURS=6
